{
  "name": "nexuscart-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "scraper",
    "shared"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "dev:scraper": "npm --workspace scraper run dev",
    "dev:all": "npx concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:scraper\""
  },
  "devDependencies": {
    "concurrently": "^8.2.1"
  }
}
